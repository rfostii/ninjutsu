#!/bin/bash

set -e

CMD=${1:-help}
INSTALL_DIR="$HOME/.ninjutsu"

case "$CMD" in
  install)
    bash "$INSTALL_DIR/install.sh"
    ;;

  doctor)
    bash "$INSTALL_DIR/doctor.sh"
    ;;

  help|*)
    echo "🥷 Ninjutsu CLI"
    echo ""
    echo "Usage:"
    echo "  ninjutsu install   Install everything"
    echo "  ninjutsu doctor    Diagnose & fix"
    ;;
esac
